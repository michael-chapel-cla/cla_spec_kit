{
  "name": "framework-nodejs-starter-kit",
  "type": "module",
  "version": "1.0.6",
  "description": "A template for a Node.js application using the CLA Framework.",
  "author": "CliftonLarsonAllen",
  "license": "ISC",
  "main": "dist/src/app.js",
  "types": "dist/src/app.d.ts",
  "scripts": {
    "start": "node dist/src/app.js",
    "dev": "tsc && npm start",
    "dev:debug": "tsc && node --inspect=0.0.0.0:9229 dist/src/app.js",
    "dev:watch": "tsx watch --inspect=0.0.0.0:9229 src/app.ts",
    "build": "tsc --declaration",
    "clean": "tsc --build --clean",
    "test": "vitest --coverage --run",
    "lint": "npx eslint src/",
    "lint:fix": "npx eslint src/ --fix",
    "prepare": "husky"
  },
  "files": [
    "dist/**/*.js",
    "dist/src/app.js",
    "dist/**/*.d.ts",
    "dist/src/app.d.ts"
  ],
  "keywords": [
    "Framework",
    "starter-kit"
  ],
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.1.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "framework-eslint-config": "^1.0.1",
    "husky": "^9.1.7",
    "jiti": "^2.5.1",
    "lint-staged": "^16.1.5",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "framework-nodejs-appconfig": "^2.1.1",
    "framework-nodejs-extensions": "^2.1.1",
    "framework-nodejs-fastify": "^2.1.2",
    "framework-nodejs-logging": "^2.1.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mts}": [
      "eslint --fix"
    ]
  }
}
