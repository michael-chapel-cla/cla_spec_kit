# Database — SQL Server connection
DB_SERVER=localhost
DB_DATABASE=ExpenseFlowDb
DB_USER=sa
DB_PASSWORD=Change_Me_123!
DB_PORT=1433

# Azure Entra — JWT validation
ENTRA_ISSUER=https://login.microsoftonline.com/<tenant-id>/v2.0
ENTRA_AUDIENCE=api://expense-flow

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000

# Azure Blob Storage — receipt images
BLOB_ACCOUNT_NAME=expenseflowstorage
BLOB_ACCOUNT_KEY=<storage-account-key>

# Email notifications — SMTP or SendGrid
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=<sendgrid-api-key>
SMTP_FROM=noreply@expense-flow.internal
